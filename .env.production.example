# Use this as a deployment checklist. Do not commit the real .env file.

POSTGRES_USER=blog_user
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=blog

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_NAME=Admin
ADMIN_ROLE=Editor-chefe

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

API_PORT=3001
WEB_PORT=80
NODE_ENV=production

# Use your final public URL here if the API is accessed cross-origin.
# Same-origin Nginx proxy does not need CORS, but keeping this set is harmless.
CORS_ORIGIN=https://your-blog-domain.example
