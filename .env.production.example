# Use this as a deployment checklist. Do not commit the real .env file.

COMPOSE_PROJECT_NAME=guandalini

POSTGRES_USER=blog_user
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=blog

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_NAME=Admin
ADMIN_ROLE=Editor-chefe

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

API_PORT=3001
NODE_ENV=production

# Public apex domain routed by Hostinger Traefik.
# The production router also accepts www.<APP_DOMAIN>.
APP_DOMAIN=luizguandalini.com.br

# O web server faz proxy same-origin, mas manter a origem publica em CORS continua sendo util.
CORS_ORIGIN=https://luizguandalini.com.br,https://www.luizguandalini.com.br

# Only used by docker-compose.standalone.yml, not by Traefik mode.
WEB_PORT=80
