# Use this as a deployment checklist. Do not commit the real .env file.

COMPOSE_PROJECT_NAME=guandalini

POSTGRES_USER=blog_user
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=blog

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_NAME=Admin
ADMIN_ROLE=Editor-chefe

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

API_PORT=3001
NODE_ENV=production

# Public domain routed by Hostinger Traefik.
# This default resolves to the VPS IP without manual DNS.
APP_DOMAIN=guandalini.177.7.40.187.sslip.io

# Same-origin Nginx proxy does not need CORS, but keeping the public origin set is harmless.
CORS_ORIGIN=https://guandalini.177.7.40.187.sslip.io

# Only used by docker-compose.standalone.yml, not by Traefik mode.
WEB_PORT=80
